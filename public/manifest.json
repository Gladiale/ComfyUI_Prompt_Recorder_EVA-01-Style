{
  "manifest_version": 3,
  "name": "ComfyUI Prompt Recorder",
  "version": "1.0.3",
  "description": "プロンプトワードを階層化されたグループへ記録・選定し、重複を排除した最終プロンプトを生成する (EVA-01 themed).",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ComfyUI Prompt Recorder"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
